{
  "compilerOptions": {
    "allowJs": false,
    "module": "node18",
    "target": "es2022",
    "moduleResolution": "node16",
    "strict": true,
    "noImplicitAny": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": false,
    "rootDir": "src",
    "outDir": "bin"
  },
  "include": ["src"]
}
